---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getCatalog, getReadyPosts, readySlugs, postUrl } from '../lib/data.mjs';

const ready = getReadyPosts();
const readySet = readySlugs();
const catalog = getCatalog();

// Feed: prefer ready posts, then fill with the rest of the catalog.
const feed = [...ready, ...catalog.filter((p) => !readySet.has(p.slug))];
const featured = feed[0];
const secondary = feed.slice(1, 5);
const wall = feed.slice(5, 17);
const total = catalog.length;

const desires = [
  'voyager', 'cuisiner', "m'évader", 'apprendre', 'entreprendre',
  'prendre soin de moi', 'recevoir', 'me lancer', 'kiffer',
];
const marquee = ['voyager', 'aimer', 'cuisiner', 'rêver', 'apprendre', 'oser', 'flâner', 'créer', 'partager', 'kiffer'];
---
<Base>
  <!-- ============================== HERO ============================== -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="eyebrow reveal in">Le magazine des envies</p>
        <h1 class="hero__title">
          <span class="hero__jaime">J'aimerais</span>
          <span class="hero__rotator-wrap">
            <span class="hero__rotator gradient-text" data-rotator={JSON.stringify(desires)}>voyager</span>
            <span class="hero__cursor" aria-hidden="true"></span>
          </span>
        </h1>
        <p class="hero__lead reveal in" data-delay="60">
          Et si on transformait vos «&nbsp;j'aimerais…&nbsp;» en projets bien réels&nbsp;? Des conseils clairs,
          des guides complets et une bonne dose d'inspiration pour <strong>oser, choisir et vivre vos envies</strong>.
        </p>
        <div class="hero__actions reveal in" data-delay="120">
          <a href="/conseils" class="btn" data-magnetic>
            Explorer les envies
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
          <a href={postUrl(featured.slug)} class="btn ghost">Le coup de cœur du moment</a>
        </div>
        <p class="hero__count reveal in" data-delay="160"><strong>{total.toLocaleString('fr-FR')}</strong> envies déjà explorées ♥</p>
      </div>

      <div class="hero__collage" aria-hidden="true">
        {feed.slice(0, 3).map((p, i) => (
          <a href={postUrl(p.slug)} class={`hero__thumb hero__thumb--${i + 1}`} data-tilt>
            {p.image?.thumb && <img src={p.image.thumb} alt="" loading="eager" width="680" height="453" />}
            <span class="hero__thumb-heart">♥</span>
          </a>
        ))}
        <span class="hero__ring hero__ring--1"></span>
        <span class="hero__ring hero__ring--2"></span>
      </div>
    </div>

    <svg class="wave hero__wave" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,50 C240,10 480,80 720,50 C960,20 1200,70 1440,40 L1440,90 L0,90 Z" fill="#fff"></path>
    </svg>
  </section>

  <!-- ============================== MARQUEE ============================== -->
  <div class="marquee-band" style="background:#fff;">
    <div class="marquee">
      <div class="marquee__track">
        {[...marquee, ...marquee].map((w) => <span>{w}</span>)}
      </div>
    </div>
  </div>

  <!-- ============================== COUP DE CŒUR ============================== -->
  <section class="section featured-sec" style="background:#fff;">
    <div class="container-wide">
      <div class="sec-head reveal">
        <p class="eyebrow">Coup de cœur</p>
        <h2>L'envie à ne pas manquer</h2>
      </div>
      <a href={postUrl(featured.slug)} class="featured reveal" data-tilt>
        <div class="featured__media">
          {featured.image?.local && <img src={featured.image.local} alt={featured.image?.alt || featured.title} loading="lazy" width="1280" height="853" />}
          <span class="featured__badge">♥ Coup de cœur</span>
        </div>
        <div class="featured__body">
          <span class="chip">À lire absolument</span>
          <h3 class="featured__title">{featured.title}</h3>
          <p class="featured__excerpt">{(featured.excerpt || '').slice(0, 200)}…</p>
          <span class="card__cta">Lire l'envie
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </span>
        </div>
      </a>

      <div class="secondary-grid">
        {secondary.map((p, i) => <div class="reveal" data-delay={i * 60}><PostCard post={p} ready={readySet.has(p.slug)} /></div>)}
      </div>
    </div>
  </section>

  <!-- ============================== LOVE BAND ============================== -->
  <section class="love-band">
    <span class="blob" style="width:40vw;height:40vw;top:-10vw;left:-6vw;background:var(--grad-love-2);opacity:.4;"></span>
    <div class="container love-band__inner reveal">
      <p class="eyebrow" style="color:#fff;">Notre petite philosophie</p>
      <h2 class="love-band__title">On ne vit qu'une fois,<br/>autant vivre ses envies.</h2>
      <div class="love-stats">
        <div class="love-stat"><span class="love-stat__v">1&nbsp;086</span><span class="love-stat__l">guides & conseils</span></div>
        <div class="love-stat"><span class="love-stat__v">100%</span><span class="love-stat__l">pensé pour vous</span></div>
        <div class="love-stat"><span class="love-stat__v">∞</span><span class="love-stat__l">envies à explorer</span></div>
      </div>
    </div>
  </section>

  <!-- ============================== LE MUR DES ENVIES ============================== -->
  <section class="section" style="background:#fff;">
    <div class="container-wide">
      <div class="sec-head reveal">
        <p class="eyebrow">Le mur des envies</p>
        <h2>Piochez l'inspiration du jour</h2>
        <p class="sec-sub">Des idées fraîches, choisies avec soin, pour nourrir toutes vos envies du moment.</p>
      </div>
      <div class="wall">
        {wall.map((p, i) => (
          <div class={`wall__item wall__item--${(i % 5) + 1} reveal`} data-delay={(i % 3) * 70}>
            <PostCard post={p} ready={readySet.has(p.slug)} />
          </div>
        ))}
      </div>
      <div class="center reveal" style="margin-top:2.6rem;">
        <a href="/conseils" class="btn" data-magnetic>Voir les {total.toLocaleString('fr-FR')} envies</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO ---------- */
  .hero { position: relative; padding: clamp(2rem, 1rem + 4vw, 4.5rem) 0 0; }
  .hero__inner { display: grid; grid-template-columns: 1.1fr .9fr; gap: 2rem; align-items: center; min-height: 66vh; }
  .hero__text { position: relative; z-index: 2; }
  .hero__title { font-size: clamp(2.8rem, 1.6rem + 6vw, 6rem); line-height: .98; margin: .6rem 0 1.3rem; }
  .hero__jaime { display: block; }
  .hero__rotator-wrap { display: inline-flex; align-items: baseline; }
  .hero__rotator { display: inline-block; font-style: italic; will-change: transform, opacity; }
  .hero__cursor { display: inline-block; width: 5px; height: .9em; background: var(--rose); margin-left: .12em; border-radius: 3px; animation: blink 1s steps(2) infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  .hero__lead { font-size: clamp(1.05rem, .95rem + .6vw, 1.3rem); color: var(--ink-soft); max-width: 46ch; line-height: 1.65; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: .9rem; margin-top: 1.8rem; }
  .hero__count { margin-top: 1.5rem; color: var(--muted); }
  .hero__count strong { color: var(--rose-deep); }

  .hero__collage { position: relative; height: 100%; min-height: 420px; }
  .hero__thumb { position: absolute; border-radius: var(--r-lg); overflow: hidden; box-shadow: var(--shadow-lg); border: 5px solid #fff; transition: transform .5s var(--ease-spring); }
  .hero__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .hero__thumb-heart { position: absolute; top: .6rem; right: .7rem; color: #fff; filter: drop-shadow(0 2px 6px rgba(0,0,0,.3)); }
  .hero__thumb--1 { width: 58%; aspect-ratio: 3/4; top: 2%; right: 8%; z-index: 3; animation: floaty 8s ease-in-out infinite; }
  .hero__thumb--2 { width: 46%; aspect-ratio: 4/3; bottom: 6%; left: 2%; z-index: 4; animation: floaty 7s ease-in-out infinite; animation-delay: -2s; }
  .hero__thumb--3 { width: 40%; aspect-ratio: 1/1; top: 42%; right: 0; z-index: 2; animation: floaty 9s ease-in-out infinite; animation-delay: -4s; }
  @media (prefers-reduced-motion: reduce){ .hero__thumb{ animation:none } }
  .hero__ring { position: absolute; border-radius: 50%; border: 2px dashed rgba(255,61,129,.35); }
  .hero__ring--1 { width: 130px; height: 130px; top: 30%; left: 24%; animation: spin 24s linear infinite; }
  .hero__ring--2 { width: 70px; height: 70px; bottom: 12%; right: 30%; border-color: rgba(166,108,255,.4); animation: spin 16s linear infinite reverse; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .hero__wave { position: relative; margin-top: 2rem; margin-bottom: -1px; }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__collage { min-height: 300px; order: -1; margin-bottom: 1rem; }
  }
  @media (max-width: 560px) { .hero__collage { display: none; } }

  /* ---------- Section heads ---------- */
  .sec-head { margin-bottom: 2.4rem; }
  .sec-head h2 { margin: .3rem 0 .4rem; }
  .sec-sub { color: var(--ink-soft); max-width: 52ch; }

  /* ---------- Featured ---------- */
  .featured { display: grid; grid-template-columns: 1.15fr 1fr; gap: 0; background: #fff; border-radius: var(--r-xl); overflow: hidden; box-shadow: var(--shadow-md); transition: box-shadow .4s; }
  .featured:hover { box-shadow: var(--shadow-lg); }
  .featured__media { position: relative; min-height: 340px; overflow: hidden; }
  .featured__media img { width: 100%; height: 100%; object-fit: cover; transition: transform .8s var(--ease-spring); }
  .featured:hover .featured__media img { transform: scale(1.06); }
  .featured__badge { position: absolute; top: 1.1rem; left: 1.1rem; background: rgba(255,255,255,.92); color: var(--rose-deep); font-weight: 700; font-size: .82rem; padding: .45rem .9rem; border-radius: 999px; box-shadow: var(--shadow-sm); }
  .featured__body { padding: clamp(1.8rem,1rem+3vw,3rem); display: flex; flex-direction: column; gap: .8rem; justify-content: center; }
  .featured__title { font-size: clamp(1.6rem, 1.2rem + 1.6vw, 2.4rem); margin: .3rem 0; }
  .featured__excerpt { color: var(--ink-soft); }
  @media (max-width: 760px) { .featured { grid-template-columns: 1fr; } .featured__media { min-height: 240px; } }

  .secondary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.4rem; margin-top: 1.6rem; }
  @media (max-width: 1000px) { .secondary-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .secondary-grid { grid-template-columns: 1fr; } }

  /* ---------- Love band ---------- */
  .love-band { position: relative; overflow: hidden; background: var(--grad-love); color: #fff; padding: clamp(3rem,2rem+5vw,6rem) 0; text-align: center; }
  .love-band__title { color: #fff; margin: .4rem 0 2rem; }
  .love-stats { display: flex; flex-wrap: wrap; justify-content: center; gap: clamp(1.5rem,1rem+4vw,4rem); }
  .love-stat__v { display: block; font-family: var(--font-display); font-weight: 640; font-size: clamp(2.4rem,1.6rem+3vw,3.6rem); line-height: 1; }
  .love-stat__l { opacity: .9; }

  /* ---------- Wall (masonry-ish) ---------- */
  .wall { columns: 3; column-gap: 1.4rem; }
  .wall__item { break-inside: avoid; margin-bottom: 1.4rem; }
  .wall__item--2, .wall__item--4 { transform: rotate(0deg); }
  @media (max-width: 900px) { .wall { columns: 2; } }
  @media (max-width: 560px) { .wall { columns: 1; } }
</style>
