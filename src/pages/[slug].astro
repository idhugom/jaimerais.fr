---
import Base from '../layouts/Base.astro';
import ArticleBlocks from '../components/ArticleBlocks.astro';
import PostCard from '../components/PostCard.astro';
import { getCatalog, getContent, readySlugs, formatDate, hashInt, topicFromSlug } from '../lib/data.mjs';
import { sanitizeHtml } from '../lib/sanitize.mjs';
import '../styles/article.css';

export function getStaticPaths() {
  return getCatalog().map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const content = getContent(post.slug);
const ready = !!content;
const ready_set = readySlugs();

const title = content?.title || post.title;
const description = content?.meta_description || post.metaDescription || post.excerpt?.slice(0, 155);
const heroImg = post.image?.local || post.image?.remote || null;
const topic = topicFromSlug(post.slug);
const readTime = content?.reading_time_min || 6;

// Related: same-ish topic first, then fill with recent ready posts.
const catalog = getCatalog();
const related = catalog
  .filter((p) => p.slug !== post.slug && ready_set.has(p.slug))
  .sort((a, b) => {
    const sa = a.slug.startsWith(post.slug.split('-')[0]) ? -1 : 0;
    const sb = b.slug.startsWith(post.slug.split('-')[0]) ? -1 : 0;
    return sa - sb || hashInt(a.slug + post.slug) - hashInt(b.slug + post.slug);
  })
  .slice(0, 3);

const ld = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: heroImg ? new URL(heroImg, 'https://jaimerais.fr').href : undefined,
  datePublished: post.date,
  dateModified: post.modified || post.date,
  author: { '@type': 'Organization', name: 'jaimerais.fr' },
  publisher: { '@type': 'Organization', name: 'jaimerais.fr' },
  mainEntityOfPage: `https://jaimerais.fr/${post.slug}`,
};
const faqLd = ready && content.faq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: content.faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: (f.a_html || '').replace(/<[^>]+>/g, ' ').trim() },
      })),
    }
  : null;
---
<Base title={title} description={description} image={heroImg || '/og-default.jpg'} article={true} noindex={!ready}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
    {faqLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />}
  </Fragment>

  <article data-article>
    <header class="art-hero">
      <div class="container art-hero__inner">
        <nav class="crumbs" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a><span>·</span><a href="/conseils">{topic}</a>
        </nav>
        <h1 class="art-title reveal">{title}</h1>
        {ready && <p class="art-intro reveal" data-delay="80">{content.hero_intro}</p>}
        <div class="art-meta reveal" data-delay="140">
          <span class="chip">{topic}</span>
          <span class="art-meta__dot">•</span>
          <span>{formatDate(post.date)}</span>
          <span class="art-meta__dot">•</span>
          <span>⏱ {readTime} min de lecture</span>
        </div>
      </div>
      {heroImg && (
        <div class="art-hero__media container">
          <img src={heroImg} alt={post.image?.alt || title} width="1280" height="853" fetchpriority="high" decoding="async" />
          <span class="art-hero__glow" aria-hidden="true"></span>
        </div>
      )}
    </header>

    <div class="container">
      <div class="article-body">
        {ready ? (
          <>
            {content.key_takeaways?.length > 0 && (
              <aside class="blk blk-essential reveal">
                <div class="essential__glow" aria-hidden="true"></div>
                <h3 class="essential__title"><span aria-hidden="true">✨</span> L'essentiel à retenir</h3>
                <ul class="essential__list">
                  {content.key_takeaways.map((k) => <li>{k}</li>)}
                </ul>
              </aside>
            )}

            {content.toc?.length > 2 && (
              <nav class="toc reveal" aria-label="Sommaire">
                <p class="toc__title">Dans cet article</p>
                <ol>{content.toc.map((t) => <li>{t}</li>)}</ol>
              </nav>
            )}

            <ArticleBlocks sections={content.sections || []} />

            {content.faq?.length > 0 && (
              <section class="blk reveal">
                <h2 class="blk-h2">Questions fréquentes</h2>
                <div class="faq">
                  {content.faq.map((f, i) => (
                    <details open={i === 0}>
                      <summary>{f.q}</summary>
                      <div class="faq__a prose prose--tight" set:html={sanitizeHtml(f.a_html)} />
                    </details>
                  ))}
                </div>
              </section>
            )}

            {content.conclusion_html && (
              <section class="blk blk-conclusion reveal">
                <h2 class="blk-h2">En résumé</h2>
                <div class="prose" set:html={sanitizeHtml(content.conclusion_html)} />
              </section>
            )}
          </>
        ) : (
          <div class="pending-note reveal">
            <span class="pending-note__icon" aria-hidden="true">💗</span>
            <h2>Cet article fait peau neuve</h2>
            <p>{post.excerpt}</p>
            <p class="pending-note__sub">Une toute nouvelle version, plus complète et plus utile, arrive très bientôt. Revenez vite&nbsp;!</p>
            <a href="/conseils" class="btn">Découvrir d'autres envies</a>
          </div>
        )}
      </div>
    </div>

    <section class="art-cta">
      <div class="container art-cta__inner">
        <p class="eyebrow">Envie d'aller plus loin</p>
        <h2>Chaque envie mérite d'être vécue</h2>
        <a href="/conseils" class="btn" data-magnetic>Explorer toutes les envies</a>
      </div>
    </section>

    {related.length > 0 && (
      <section class="section related">
        <div class="container">
          <p class="eyebrow">À lire aussi</p>
          <h2 class="related__title">D'autres envies qui vous ressemblent</h2>
          <div class="grid-3">
            {related.map((p) => <PostCard post={p} ready={ready_set.has(p.slug)} />)}
          </div>
        </div>
      </section>
    )}
  </article>

  <style>
    .art-hero { padding-top: 1.5rem; }
    .art-hero__inner { max-width: 820px; text-align: center; }
    .crumbs { display: flex; gap: .5rem; justify-content: center; color: var(--muted); font-size: .9rem; margin-bottom: 1.2rem; }
    .crumbs a { color: var(--rose-deep); font-weight: 600; }
    .art-title { margin: 0 auto .8rem; max-width: 16ch; }
    .art-intro { font-size: 1.2rem; color: var(--ink-soft); max-width: 60ch; margin: 0 auto 1.4rem; line-height: 1.6; }
    .art-meta { display: flex; flex-wrap: wrap; gap: .6rem; justify-content: center; align-items: center; color: var(--muted); font-size: .92rem; }
    .art-meta__dot { color: var(--rose); }
    .art-hero__media { position: relative; margin-top: 2.2rem; }
    .art-hero__media img { width: 100%; border-radius: var(--r-xl); box-shadow: var(--shadow-lg); aspect-ratio: 3/2; object-fit: cover; }
    .art-hero__glow { position: absolute; inset: 8% 6% -6%; z-index: -1; background: var(--grad-love); filter: blur(70px); opacity: .3; border-radius: 50%; }

    .toc { background: #fff; border-radius: var(--r-md); padding: 1.4rem 1.6rem; box-shadow: var(--shadow-sm); margin-block: 2rem; }
    .toc__title { font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; margin: 0 0 .7rem; }
    .toc ol { margin: 0; padding-left: 0; list-style: none; counter-reset: t; display: grid; gap: .45rem; }
    .toc li { counter-increment: t; position: relative; padding-left: 2rem; color: var(--ink-soft); }
    .toc li::before { content: counter(t, decimal-leading-zero); position: absolute; left: 0; color: var(--rose); font-weight: 700; font-family: var(--font-display); }

    .blk-conclusion { background: linear-gradient(135deg,#fff5f9,#fff); border-radius: var(--r-lg); padding: 1.8rem 2rem; box-shadow: var(--shadow-sm); }

    .pending-note { text-align: center; background: #fff; border-radius: var(--r-lg); padding: 3rem 2rem; box-shadow: var(--shadow-md); margin-block: 2rem; }
    .pending-note__icon { font-size: 3rem; display: block; margin-bottom: 1rem; }
    .pending-note__sub { color: var(--ink-soft); margin-bottom: 1.6rem; }

    .art-cta { margin-top: 3.5rem; }
    .art-cta__inner { text-align: center; background: var(--grad-soft); border-radius: var(--r-xl); padding: clamp(2.5rem,1.5rem+4vw,4.5rem) 1.5rem; box-shadow: inset 0 0 0 1px rgba(255,61,129,.1); }
    .art-cta__inner h2 { margin: .4rem 0 1.4rem; }

    .related__title { margin-bottom: 2rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
    @media (max-width: 900px) { .grid-3 { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .grid-3 { grid-template-columns: 1fr; } }
  </style>
</Base>
