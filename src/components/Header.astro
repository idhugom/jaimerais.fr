---
const path = Astro.url.pathname;
const isActive = (href) => (href === '/' ? path === '/' : path.startsWith(href));
const links = [
  { href: '/', label: 'Accueil' },
  { href: '/conseils', label: 'Les envies' },
  { href: '/a-propos', label: 'À propos' },
];
---
<header class="site-header" data-header>
  <div class="container-wide site-header__inner">
    <a href="/" class="brand" aria-label="jaimerais.fr, accueil">
      <span class="brand__mark" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-8-5.3-8-11a4.5 4.5 0 0 1 8-2.8A4.5 4.5 0 0 1 20 10c0 5.7-8 11-8 11z"/></svg>
      </span>
      <span class="brand__text">jaimerais<span class="brand__dot">.fr</span></span>
    </a>

    <nav class="site-nav" aria-label="Navigation principale">
      {links.map((l) => (
        <a href={l.href} class={`site-nav__link${isActive(l.href) ? ' active' : ''}`}>{l.label}</a>
      ))}
    </nav>

    <a href="/conseils" class="btn header-cta" data-magnetic>
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3-3"/></svg>
      Explorer
    </a>

    <button class="burger" aria-label="Ouvrir le menu" data-burger>
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" data-mobile-menu>
    {links.map((l) => <a href={l.href} class="mobile-menu__link">{l.label}</a>)}
    <a href="/conseils" class="btn" style="margin-top:.5rem;">Explorer les envies</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 8000;
    padding: 1rem 0;
    transition: padding .35s var(--ease-spring), background .35s, box-shadow .35s;
  }
  .site-header.scrolled {
    padding: .55rem 0;
    background: rgba(255, 247, 244, .78);
    backdrop-filter: blur(16px) saturate(1.3);
    box-shadow: 0 10px 30px -20px rgba(226, 31, 109, .5);
  }
  .site-header__inner { display: flex; align-items: center; gap: 1.2rem; }

  .brand { display: inline-flex; align-items: center; gap: .55rem; }
  .brand__mark {
    display: grid; place-items: center; width: 40px; height: 40px; border-radius: 13px;
    color: #fff; background: var(--grad-love); box-shadow: var(--shadow-sm);
    animation: heartbeat 2.6s ease-in-out infinite;
  }
  @keyframes heartbeat { 0%,100%{transform:scale(1)} 12%{transform:scale(1.16)} 24%{transform:scale(1)} 36%{transform:scale(1.1)} }
  @media (prefers-reduced-motion: reduce){ .brand__mark{animation:none} }
  .brand__text { font-family: var(--font-display); font-weight: 600; font-size: 1.35rem; letter-spacing: -.02em; }
  .brand__dot { color: var(--rose); }

  .site-nav { display: flex; gap: .3rem; margin-left: auto; }
  .site-nav__link {
    position: relative; padding: .5rem .9rem; border-radius: 999px; font-weight: 600; color: var(--ink-soft);
    transition: color .3s, background .3s;
  }
  .site-nav__link::after {
    content: ""; position: absolute; left: 50%; bottom: .28rem; width: 0; height: 3px; border-radius: 3px;
    background: var(--grad-love); transform: translateX(-50%); transition: width .3s var(--ease-spring);
  }
  .site-nav__link:hover { color: var(--ink); }
  .site-nav__link:hover::after, .site-nav__link.active::after { width: 22px; }
  .site-nav__link.active { color: var(--rose-deep); }

  .header-cta { padding: .7rem 1.25rem; font-size: .95rem; margin-left: .4rem; }

  .burger { display: none; flex-direction: column; gap: 5px; background: none; border: 0; margin-left: auto; padding: .4rem; }
  .burger span { width: 26px; height: 3px; border-radius: 3px; background: var(--ink); transition: .3s; }
  .burger.open span:nth-child(1){ transform: translateY(8px) rotate(45deg); }
  .burger.open span:nth-child(2){ opacity: 0; }
  .burger.open span:nth-child(3){ transform: translateY(-8px) rotate(-45deg); }

  .mobile-menu {
    display: none; flex-direction: column; gap: .3rem; padding: 0 1.25rem;
    max-height: 0; overflow: hidden; transition: max-height .4s var(--ease-spring), padding .4s;
  }
  .mobile-menu.open { max-height: 60vh; padding: 1rem 1.25rem 1.4rem; }
  .mobile-menu__link { padding: .7rem .4rem; font-weight: 600; font-size: 1.1rem; border-bottom: 1px solid var(--line); }

  @media (max-width: 820px) {
    .site-nav, .header-cta { display: none; }
    .burger { display: flex; }
    .mobile-menu { display: flex; }
    .site-header.scrolled { background: rgba(255,247,244,.92); }
  }
</style>

<script>
  const burger = document.querySelector('[data-burger]');
  const menu = document.querySelector('[data-mobile-menu]');
  burger?.addEventListener('click', () => {
    burger.classList.toggle('open');
    menu?.classList.toggle('open');
  });
</script>
